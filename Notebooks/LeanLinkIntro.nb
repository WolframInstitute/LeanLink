  LeanLink`LeanEnvironment[<|
   "Ax1" -> LeanLink`LeanTerm[<|
      "Name" -> "Ax1", "Kind" -> "axiom", "_TypeExpr" -> 
       LeanLink`LeanForall["b", 
         LeanLink`LeanConst["U", {}], 
         LeanLink`LeanForall["a", 
          LeanLink`LeanConst["U", {}], 
          LeanLink`LeanApp[
