Cell["Importing from Mathlib", "Chapter",ExpressionUUID->"f32a0121-46f6-48e9-b3c0-b9745ebaaab6"],

Cell[TextData[{
 "LeanLink can import theorems from any Lean project. Point ",
 Cell["\"ProjectDir\"", "InlineCode",ExpressionUUID->
  "4616334b-9396-43a2-8d0a-01ce5b0650d9"],
 " at a mathlib4 checkout where ",
 Cell["lake exe cache get && lake build Mathlib.Tactic.Ring", "InlineCode",
  ExpressionUUID->"6f10d604-e61c-4e29-909f-13ef70832128"],
 " has been run:"
}], "Text",ExpressionUUID->"05261974-6209-445f-a1a5-5b39fbf2783c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"mathlibDir", " ", "=", " ", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
     "$HomeDirectory", ",", " ", "\"\<src\>\"", ",", 
      " ", "\"\<mathlib4\>\""}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"DirectoryQ", "[", 
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{
      "mathlibDir", ",", " ", "\"\<.lake\>\"", ",", " ", "\"\<build\>\""}], 
      "}"}], "]"}], "]"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"mathEnv", " ", "=", " ", 
     RowBox[{"LeanImport", "[", 
      RowBox[{"\"\<Mathlib.Tactic.Ring\>\"", ",", "\n", "    ", 
       RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "mathlibDir"}], ",", 
       "\n", "    ", 
       RowBox[{"\"\<Imports\>\"", " ", "->", " ", 
        RowBox[{"{", "\"\<Mathlib.Tactic.Ring\>\"", "}"}]}], ",", "\n", 
       "    ", 
       RowBox[{"\"\<Filter\>\"", " ", "->", " ", "\"\<Ring\>\""}]}], "]"}]}], 
    ";", "\n", "  ", 
    RowBox[{"Keys", "[", "mathEnv", "]"}]}], ",", "\n", 
   "  ", "\"\<Mathlib not built \[LongDash] run in mathlib4/: lake exe cache \
get && lake build Mathlib.Tactic.Ring\>\""}], "]"}]}], "Input",ExpressionUUID->\
"cc1bbb41-2da3-45a6-9774-060f2cb7dacc"],

