Cell[BoxData[
 InterpretationBox[
  StyleBox["\<\"exact h\"\>", "Input",
   StripOnInput->False],
  LeanLink`LeanTactic["exact", 
   LeanLink`LeanConst["h", {}]]]], "Output",ExpressionUUID->"acefae47-dcdd-\
4540-ae13-33d8e65d6bcc"],

Cell[BoxData[
 RowBox[{"LeanTactic", "[", 
  RowBox[{"{", "\n", "  ", 
   RowBox[{
    RowBox[{"LeanTactic", "[", 
     RowBox[{"\"\<intro\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<P\>\"", ",", " ", "\"\<h\>\""}], "}"}]}], "]"}], ",", 
    "\n", "  ", 
    RowBox[{"LeanTactic", "[", 
     RowBox[{"\"\<exact\>\"", ",", " ", 
      RowBox[{"LeanConst", "[", "\"\<h\>\"", "]"}]}], "]"}]}], "\n", "}"}], 
  "]"}]], "Input",ExpressionUUID->"ba44520d-3363-4e89-bf59-1a74d8674ebf"],

Cell[BoxData[
 InterpretationBox[
  TagBox[GridBox[{
     {
      StyleBox["\<\"intro P h\"\>", "Input",
       StripOnInput->False]},
     {
      StyleBox["\<\"exact h\"\>", "Input",
       StripOnInput->False]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Left}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}},
    GridBoxSpacings->{"Columns" -> {{Automatic}}, "Rows" -> {{0.2}}}],
   "Column"],
  LeanLink`LeanTactic[{
    LeanLink`LeanTactic["intro", {"P", "h"}], 
    LeanLink`LeanTactic["exact", 
     LeanLink`LeanConst["h", {}]]}]]], "Output",ExpressionUUID->"99117bba-\
5a3b-47f7-ab70-72a86f6b49cb"],

