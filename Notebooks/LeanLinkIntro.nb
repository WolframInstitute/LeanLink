            LeanLink`LeanConst["b", {}]], 
           LeanLink`LeanConst["c", {}]], "default"], "default"]|>], "Hyp1" -> 
    LeanLink`LeanTerm[<|
      "Name" -> "Hyp1", "Kind" -> "axiom", "_TypeExpr" -> 
       LeanLink`LeanForall["a", 
         LeanLink`LeanConst["U", {}], 
         LeanLink`LeanForall["c", 
          LeanLink`LeanConst["U", {}], 
          LeanLink`LeanApp[
           LeanLink`LeanApp[
            LeanLink`LeanApp[
             LeanLink`LeanConst["Eq", {
               LeanLink`LeanLevelSucc[
                LeanLink`LeanLevelZero[]]}], 
             LeanLink`LeanConst["U", {}]], 
            LeanLink`LeanConst["a", {}]], 
           LeanLink`LeanConst["c", {}]], "default"], "default"]|>], "SL1" -> 
    LeanLink`LeanTerm[<|
      "Name" -> "SL1", "Kind" -> "theorem", "_TypeExpr" -> 
       LeanLink`LeanForall["a", 
         LeanLink`LeanConst["U", {}], 
         LeanLink`LeanForall["c", 
          LeanLink`LeanConst["U", {}], 
          LeanLink`LeanApp[
           LeanLink`LeanApp[
            LeanLink`LeanApp[
             LeanLink`LeanConst["Eq", {
               LeanLink`LeanLevelSucc[
                LeanLink`LeanLevelZero[]]}], 
             LeanLink`LeanConst["U", {}]], 
            LeanLink`LeanConst["a", {}]], 
           LeanLink`LeanConst["c", {}]], "default"], "default"], "_Tactic" -> 
       LeanLink`LeanTactic[{
          LeanLink`LeanTactic["intro", {"a", "c"}], 
          LeanLink`LeanTactic["have", "h", 
           LeanLink`LeanApp[
            LeanLink`LeanApp[
             LeanLink`LeanConst["Ax2", {}], 
             LeanLink`LeanConst["a", {}]], 
            LeanLink`LeanConst["c", {}]]], 
          LeanLink`LeanTactic["conv", "h", {"lhs"}, 
           LeanLink`LeanTactic["simp", {
             LeanLink`LeanConst["Ax1", {}]}]], 
          LeanLink`LeanTactic["exact", 
           LeanLink`LeanConst["h", {}]]}]|>], "FinalGoal" -> 
    LeanLink`LeanTerm[<|
      "Name" -> "FinalGoal", "Kind" -> "theorem", "_TypeExpr" -> 
       LeanLink`LeanForall["a", 
         LeanLink`LeanConst["U", {}], 
         LeanLink`LeanForall["c", 
          LeanLink`LeanConst["U", {}], 
          LeanLink`LeanApp[
           LeanLink`LeanApp[
            LeanLink`LeanApp[
             LeanLink`LeanConst["Eq", {
               LeanLink`LeanLevelSucc[
                LeanLink`LeanLevelZero[]]}], 
             LeanLink`LeanConst["U", {}]], 
            LeanLink`LeanConst["a", {}]], 
           LeanLink`LeanConst["c", {}]], "default"], "default"], "_Tactic" -> 
       LeanLink`LeanTactic[{
          LeanLink`LeanTactic["intro", {"a", "c"}], 
          LeanLink`LeanTactic["exact", 
           LeanLink`LeanApp[
            LeanLink`LeanApp[
             LeanLink`LeanConst["SL1", {}], 
             LeanLink`LeanConst["a", {}]], 
            LeanLink`LeanConst["c", {}]]]}]|>], 
    "_Preamble" -> <|
     "Imports" -> {}, "TypeAxiom" -> "U", "Operators" -> <||>, "CenterDot" -> 
      False, "SharedConstants" -> {}|>, 
    "_DeclOrder" -> {"Ax1", "Ax2", "Hyp1", "SL1", "FinalGoal"}, "_Source" -> 
    "\naxiom U : Type\n\n\naxiom Ax1 : \[ForAll] (b : U) (a : U), b = a\n\
axiom Ax2 : \[ForAll] (b : U) (c : U), b = c\naxiom Hyp1 : \[ForAll] (a : U) \
(c : U), a = c\ntheorem SL1 : \[ForAll] (a : U) (c : U), a = c := by\n  intro \
a c\n  have h := (Ax2 a c)\n  conv at h => lhs; simp only [Ax1]\n  exact h\n\n\
theorem FinalGoal : \[ForAll] (a : U) (c : U), a = c := by\n  intro a c\n  \
exact (SL1 a c)\n"|>],
  Editable->False,
  SelectWithContents->True,
