Cell[TextData[{
 "LeanLink can import theorems from any Lean project. Point ",
 Cell["\"ProjectDir\"", "InlineCode",ExpressionUUID->
  "561cc1c5-d1f0-4046-916b-719b395a98e2"],
 " at a mathlib4 checkout where ",
 Cell["lake exe cache get && lake build Mathlib.Tactic.Ring", "InlineCode",
  ExpressionUUID->"e16266fa-afca-4946-8387-dcc2c6110b50"],
 " has been run:"
}], "Text",ExpressionUUID->"a917e0d1-5d07-41b7-b2b7-7a26a4ac4194"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"mathlibDir", " ", "=", " ", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
     "$HomeDirectory", ",", " ", "\"\<src\>\"", ",", 
      " ", "\"\<mathlib4\>\""}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"DirectoryQ", "[", 
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{
      "mathlibDir", ",", " ", "\"\<.lake\>\"", ",", " ", "\"\<build\>\""}], 
      "}"}], "]"}], "]"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"mathEnv", " ", "=", " ", 
     RowBox[{"LeanImport", "[", 
      RowBox[{"\"\<Mathlib.Tactic.Ring\>\"", ",", "\n", "    ", 
       RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "mathlibDir"}], ",", 
       "\n", "    ", 
       RowBox[{"\"\<Imports\>\"", " ", "->", " ", 
        RowBox[{"{", "\"\<Mathlib.Tactic.Ring\>\"", "}"}]}], ",", "\n", 
       "    ", 
       RowBox[{"\"\<Filter\>\"", " ", "->", " ", "\"\<Ring\>\""}]}], "]"}]}], 
    ";", "\n", "  ", 
    RowBox[{"Keys", "[", "mathEnv", "]"}]}], ",", "\n", 
   "  ", "\"\<Mathlib not built \[LongDash] run in mathlib4/: lake exe cache \
get && lake build Mathlib.Tactic.Ring\>\""}], "]"}]}], "Input",ExpressionUUID->\
"d9c40a68-aeeb-420f-868d-5e71aebfdda6"],

