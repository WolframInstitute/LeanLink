Cell["Importing from Mathlib", "Chapter",ExpressionUUID->"09d65d85-815e-4244-98e0-a0030260614b"],

Cell[TextData[{
 "LeanLink can import theorems from any Lean project. Point ",
 Cell["\"ProjectDir\"", "InlineCode",ExpressionUUID->
  "1db43a95-0592-413b-a772-ffbef38cb66e"],
 " at a mathlib4 checkout where ",
 Cell["lake exe cache get && lake build Mathlib.Tactic.Ring", "InlineCode",
  ExpressionUUID->"77d00399-7c41-4a8e-8148-ae0145d711d3"],
 " has been run:"
}], "Text",ExpressionUUID->"54110fbd-d13e-4bef-8cb9-78c5f8ff1535"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mathlibDir", " ", "=", " ", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
     "$HomeDirectory", ",", " ", "\"\<src\>\"", ",", 
      " ", "\"\<mathlib4\>\""}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"DirectoryQ", "[", 
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{
      "mathlibDir", ",", " ", "\"\<.lake\>\"", ",", " ", "\"\<build\>\""}], 
      "}"}], "]"}], "]"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"mathEnv", " ", "=", " ", 
     RowBox[{"LeanImport", "[", 
      RowBox[{"\"\<Mathlib.Tactic.Ring\>\"", ",", "\n", "    ", 
       RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "mathlibDir"}], ",", 
       "\n", "    ", 
       RowBox[{"\"\<Imports\>\"", " ", "->", " ", 
        RowBox[{"{", "\"\<Mathlib.Tactic.Ring\>\"", "}"}]}], ",", "\n", 
       "    ", 
       RowBox[{"\"\<Filter\>\"", " ", "->", " ", "\"\<Ring\>\""}]}], "]"}]}], 
    ";", "\n", "  ", 
    RowBox[{"Length", "[", "mathEnv", "]"}]}], ",", "\n", 
   "  ", "\"\<Mathlib not built \[LongDash] run in mathlib4/: lake exe cache \
get && lake build Mathlib.Tactic.Ring\>\""}], "]"}]}], "Input",
 CellLabel->"In[41]:=",ExpressionUUID->"52185cf7-d517-48d6-88f1-c64493ce5357"],

Cell[BoxData["2439"], "Output",
 CellLabel->"Out[41]=",ExpressionUUID->"1008bb86-574c-497b-ba6a-f3c95ed772a7"]
}, Open  ]],

