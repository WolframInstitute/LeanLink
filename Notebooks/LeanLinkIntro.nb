  RowBox[{"{", "\n", "  ", 
   RowBox[{
    RowBox[{"LeanTactic", "[", 
     RowBox[{"\"\<intro\>\"", ",", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<P\>\"", ",", " ", "\"\<h\>\""}], "}"}]}], "]"}], ",", 
    "\n", "  ", 
    RowBox[{"LeanTactic", "[", 
     RowBox[{"\"\<exact\>\"", ",", " ", 
      RowBox[{"LeanConst", "[", "\"\<h\>\"", "]"}]}], "]"}]}], "\n", "}"}], 
  "]"}]], "Input",
 CellLabel->"In[43]:=",ExpressionUUID->"5f235e90-7453-451a-9f7b-2cb5d3193bff"],

Cell[BoxData[
 InterpretationBox[
  TagBox[GridBox[{
     {
      StyleBox["\<\"intro P h\"\>", "Input",
       StripOnInput->False]},
     {
      StyleBox["\<\"exact h\"\>", "Input",
       StripOnInput->False]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Left}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}},
    GridBoxSpacings->{"Columns" -> {{Automatic}}, "Rows" -> {{0.2}}}],
   "Column"],
  LeanLink`LeanTactic[{
    LeanLink`LeanTactic["intro", {"P", "h"}], 
    LeanLink`LeanTactic["exact", 
     LeanLink`LeanConst["h", {}]]}]]], "Output",
 CellLabel->"Out[43]=",ExpressionUUID->"268bb688-64b6-4461-b475-1d53bf643763"]
}, Open  ]],

Cell["Apply structured tactics to proof states:", "Text",ExpressionUUID->"bae047ba-5635-4480-94b6-cb7d7da8bedd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"s0", " ", "=", " ", 
   RowBox[{"LeanState", "[", 
    RowBox[{"env", "[", "\"\<id_proof\>\"", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"s1", " ", "=", " ", 
   RowBox[{
    RowBox[{"LeanTactic", "[", 
     RowBox[{"\"\<intro\>\"", ",", " ", 
      RowBox[{"{", "\"\<P\>\"", "}"}]}], "]"}], "[", "s0", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"s2", " ", "=", " ", 
   RowBox[{
    RowBox[{"LeanTactic", "[", 
     RowBox[{"\"\<intro\>\"", ",", " ", 
      RowBox[{"{", "\"\<h\>\"", "}"}]}], "]"}], "[", "s1", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"s3", " ", "=", " ", 
   RowBox[{
    RowBox[{"LeanTactic", "[", 
     RowBox[{"\"\<exact\>\"", ",", " ", 
      RowBox[{"LeanConst", "[", "\"\<h\>\"", "]"}]}], "]"}], "[", "s2", 
    "]"}]}], ";"}], "\n", 
 RowBox[{"s3", "[", "\"\<Complete\>\"", "]"}]}], "Input",
 CellLabel->"In[44]:=",ExpressionUUID->"79ac81c8-50ff-40b1-b353-53d2ba5ec7d1"],

