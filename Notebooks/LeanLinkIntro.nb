Cell[BoxData[
 InterpretationBox[
  RowBox[{
   RowBox[{"(", 
    StyleBox["P",
     FontSlant->Italic], 
    RowBox[{" ", 
     RowBox[{":", " "}]}], 
    InterpretationBox[
     StyleBox["Prop",
      FontWeight->Bold,
      FontColor->RGBColor[0.6, 0.2, 0.6]],
     LeanLink`LeanSort[
      LeanLink`LeanLevelZero[]]], ")"}], 
   StyleBox[
    RowBox[{" ", 
     RowBox[{"\[Implies]", " "}]}],
    FontColor->GrayLevel[0.4]], 
   InterpretationBox[
    RowBox[{
     RowBox[{"(", 
      StyleBox["a",
       FontSlant->Italic], 
      RowBox[{" ", 
       RowBox[{":", " "}]}], 
      InterpretationBox[
       TooltipBox[
        StyleBox["#0",
         FontColor->GrayLevel[0.5]],
        RowBox[{"bound var ", "0"}]],
       LeanLink`LeanBVar[0]], ")"}], 
     StyleBox[
      RowBox[{" ", 
       RowBox[{"\[Implies]", " "}]}],
      FontColor->GrayLevel[0.4]], 
     InterpretationBox[
      TooltipBox[
       StyleBox["#1",
        FontColor->GrayLevel[0.5]],
       RowBox[{"bound var ", "1"}]],
      LeanLink`LeanBVar[1]]}],
    LeanLink`LeanForall["a._@._internal._hyg.0", 
     LeanLink`LeanBVar[0], 
     LeanLink`LeanBVar[1], "default"]]}],
  LeanLink`LeanForall["P", 
   LeanLink`LeanSort[
    LeanLink`LeanLevelZero[]], 
   LeanLink`LeanForall["a._@._internal._hyg.0", 
    LeanLink`LeanBVar[0], 
    LeanLink`LeanBVar[1], "default"], "default"]]], "Output",ExpressionUUID->\
"6ba17888-c7ef-4093-bf73-854fc5bf4859"],

