Cell["Importing from Mathlib", "Chapter",ExpressionUUID->"f383d651-b8b7-4b43-a906-8815a1e3529d"],

Cell[TextData[{
 "LeanLink can import theorems from any Lean project. Point ",
 Cell["\"ProjectDir\"", "InlineCode",ExpressionUUID->
  "70f0a96e-0713-4cbc-a1ca-9d1a4fe34f4c"],
 " at a mathlib4 checkout where ",
 Cell["lake exe cache get && lake build Mathlib.Tactic.Ring", "InlineCode",
  ExpressionUUID->"353ec70d-a95e-4fb9-a355-4504f22c2264"],
 " has been run:"
}], "Text",ExpressionUUID->"6187a864-6327-4fd7-b929-23a4ab251079"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mathlibDir", " ", "=", " ", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
     "$HomeDirectory", ",", " ", "\"\<src\>\"", ",", 
      " ", "\"\<mathlib4\>\""}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"DirectoryQ", "[", 
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{
      "mathlibDir", ",", " ", "\"\<.lake\>\"", ",", " ", "\"\<build\>\""}], 
      "}"}], "]"}], "]"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"mathEnv", " ", "=", " ", 
     RowBox[{"LeanImport", "[", 
      RowBox[{"\"\<Mathlib.Tactic.Ring\>\"", ",", "\n", "    ", 
       RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "mathlibDir"}], ",", 
       "\n", "    ", 
       RowBox[{"\"\<Imports\>\"", " ", "->", " ", 
        RowBox[{"{", "\"\<Mathlib.Tactic.Ring\>\"", "}"}]}], ",", "\n", 
       "    ", 
       RowBox[{"\"\<Filter\>\"", " ", "->", " ", "\"\<Ring\>\""}]}], "]"}]}], 
    ";", "\n", "  ", 
    RowBox[{"Keys", "[", "mathEnv", "]"}]}], ",", "\n", 
   "  ", "\"\<Mathlib not built \[LongDash] run in mathlib4/: lake exe cache \
get && lake build Mathlib.Tactic.Ring\>\""}], "]"}]}], "Input",
 CellLabel->"In[41]:=",ExpressionUUID->"621f5184-13ff-4c9a-927d-c40857ca9054"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"Null", ",", "Null", ",", 
   RowBox[{"{", 
    RowBox[{"\<\"RingHomClass.toMonoidWithZeroHomClass\"\>", 
     ",", "\<\"Lean.Meta.Grind.Arith.CommRing.State.exprToRingId._default\"\>\
", ",", "\<\"Lean.Meta.Grind.Arith.CommRing.NonCommSemiringM.modifySemiring\"\
\>", ",", "\<\"Lean.Grind.CommRing.Expr.num.elim\"\>", 
     ",", "\<\"RingHom.copy._proof_2\"\>", 
     ",", "\<\"Mathlib.Tactic.Ring.Result.ctorIdx\"\>", 
