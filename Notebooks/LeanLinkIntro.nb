           LeanLink`LeanConst["a", {}]], "default"], "default"]|>], "Ax2" -> 
    LeanLink`LeanTerm[<|
      "Name" -> "Ax2", "Kind" -> "axiom", "_TypeExpr" -> 
       LeanLink`LeanForall["b", 
         LeanLink`LeanConst["U", {}], 
         LeanLink`LeanForall["c", 
          LeanLink`LeanConst["U", {}], 
