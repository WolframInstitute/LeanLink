Cell["Part 6: The Fundamental Theorem of Algebra", "Chapter",ExpressionUUID->"89463f44-672a-4d30-8cb6-7527c9d44803"],

Cell[TextData[{
 "The FTA states that ",
 Cell[TextData[{
  Cell[BoxData[
   FormBox[
    StyleBox["C",
     FontSlant->"Plain"], TraditionalForm]], "InlineFormula",ExpressionUUID->
   "c872ad0d-ce9b-4606-b99f-db2fabf71ed0"],
  "  "
 }], "DisplayFormula",ExpressionUUID->
  "2533d5e9-ee2f-4274-84da-7ed59d17c2f5"],
 " is algebraically closed: every non-constant polynomial over ",
 Cell[TextData[{
  Cell[BoxData[
   FormBox[
    StyleBox["C",
     FontSlant->"Plain"], TraditionalForm]], "InlineFormula",ExpressionUUID->
   "d4ee5f47-27db-4b0c-a6ae-d0943f3618be"],
  "  "
 }], "DisplayFormula",ExpressionUUID->
  "d9997531-e1f2-4d08-8aa6-0b1cb08278b9"],
 " has a root. In Mathlib, this is captured by the ",
 Cell["IsAlgClosed", "InlineCode",ExpressionUUID->
  "06410b89-8a58-4556-b276-e3d24bd98f07"],
 " typeclass."
}], "Text",ExpressionUUID->"07af00bc-f1bb-4a88-8e8d-cf0f7872856e"],

