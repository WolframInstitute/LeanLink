Cell["The core theorem: existence of roots", "Section",ExpressionUUID->"07e9b0cb-d812-4f3b-8048-8e8154ed260f"],

Cell[TextData[{
 Cell["IsAlgClosed.exists_aeval_eq_zero", "InlineCode",ExpressionUUID->
  "efc8f0b6-ca1b-40f2-af15-3235f9936685"],
 " says: for any polynomial of non-zero degree over an algebraically closed \
field, there exists a root:"
}], "Text",ExpressionUUID->"651c1fcb-5fe2-4ce5-9d52-2eaa1cd9d65b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ftaEnv", "[", "\"\<IsAlgClosed.exists_aeval_eq_zero\>\"", "]"}], 
  "[", "\"\<TypeForm\>\"", "]"}]], "Input",
 CellLabel->"In[30]:=",ExpressionUUID->"65d6017b-0bf7-4993-b7b7-702c0981f1a4"],

Cell[BoxData["\<\"\[ForAll] (k : Type u) [inst : Field k] {R : Type u_1} \
[inst : CommSemiring R] [inst : IsAlgClosed k inst] [inst : Algebra R k inst \
DivisionSemiring.toSemiring k Semifield.toDivisionSemiring k \
Field.toSemifield k inst], \[ForAll] [inst : FaithfulSMul R k Algebra.toSMul \
R k inst DivisionSemiring.toSemiring k Semifield.toDivisionSemiring k \
Field.toSemifield inst] (p : Polynomial R CommSemiring.toSemiring R inst) (hp \
: Polynomial.degree R CommSemiring.toSemiring R inst p \[NotEqual] 0), \
\[Exists] x, DFunLike.coe AlgHom R Polynomial k inst Polynomial.semiring \
DivisionSemiring.toSemiring Polynomial.algebraOfAlgebra inst Polynomial R \
CommSemiring.toSemiring \[Lambda] (x : Polynomial) \[DoubleLongRightArrow] k \
AlgHom.funLike R Polynomial k inst Polynomial.semiring \
DivisionSemiring.toSemiring Polynomial.algebraOfAlgebra inst Polynomial.aeval \
R k inst DivisionSemiring.toSemiring inst #0 p = 0\"\>"], "Output",
 CellLabel->"Out[30]=",ExpressionUUID->"8b92610a-3ce3-4686-9dd5-0a8bda266310"]
}, Open  ]],

