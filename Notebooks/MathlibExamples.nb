Notebook[{
Cell["LeanLink \[LongDash] Exploring Mathlib", "Title",ExpressionUUID->"828f4e75-5a0b-455b-bfcc-fdd2f6103bd7"],

Cell["Prerequisites: Installing Mathlib", "Chapter",ExpressionUUID->"700d9494-218a-40a2-aa19-b913545e0a54"],

Cell["\<\
Install elan (Lean version manager) if not already installed:\
\>", "Text",ExpressionUUID->"08e50a8a-1293-47f9-911b-3e3e5b780cab"],

Cell["\<\
(* Terminal: curl https://elan.lean-lang.org/install.sh | sh *)\
\>", "Program",ExpressionUUID->"e429a75e-1083-47fc-94e7-41af1693b006"],

Cell["\<\
Create a Lean project with Mathlib as a dependency and build the modules used \
in this notebook:\
\>", "Text",ExpressionUUID->"ae488afa-c484-41ae-af9b-de06da529e76"],

Cell["\<\
(* Terminal:
   mkdir -p ~/src/mathlib4 && cd ~/src/mathlib4
   lake init MathlibTest math
   lake exe cache get
   lake build Mathlib.Tactic.Ring
   lake build Mathlib.Algebra.Group.Basic
   lake build Mathlib.Logic.Basic
   lake build Mathlib.FieldTheory.IsAlgClosed.Basic
*)\
\>", "Program",ExpressionUUID->"e45cd95a-3148-4074-b180-22ba9738ff05"],

Cell["Setup", "Chapter",ExpressionUUID->"d1667bf1-0c55-4139-ab3a-a89255a64b8b"],

