      LeanLink`LeanGoal[<|
       "target" -> 
        "\[ForAll] {M : Type u} [inst : MulOneClass M] (a : M), Eq \
(instHMul.hMul a 1) a", "targetExpr" -> LeanLink`LeanForall["M", 
          LeanLink`LeanSort[
           LeanLink`LeanLevelSucc[
            LeanLink`LeanLevelParam["u"]]], 
          LeanLink`LeanForall[
          "inst._@.Mathlib.Algebra.Group.Defs.1575903989._hygCtx._hyg.4", 
