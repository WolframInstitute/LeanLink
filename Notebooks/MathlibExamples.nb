            LeanLink`LeanBVar[0]], 
           LeanLink`LeanForall["a", 
            LeanLink`LeanBVar[1], 
            LeanLink`LeanApp[
             LeanLink`LeanApp[
              LeanLink`LeanApp[
               LeanLink`LeanConst["Eq", {
                 LeanLink`LeanLevelSucc[
                  LeanLink`LeanLevelParam["u"]]}], 
               LeanLink`LeanBVar[2]], 
              LeanLink`LeanApp[
               LeanLink`LeanApp[
                LeanLink`LeanApp[
                 LeanLink`LeanApp[
                  LeanLink`LeanApp[
                   LeanLink`LeanApp[
                    LeanLink`LeanConst["HMul.hMul", {
                    LeanLink`LeanLevelParam["u"], 
                    LeanLink`LeanLevelParam["u"], 
                    LeanLink`LeanLevelParam["u"]}], 
                    LeanLink`LeanBVar[2]], 
                   LeanLink`LeanBVar[2]], 
                  LeanLink`LeanBVar[2]], 
                 LeanLink`LeanApp[
                  LeanLink`LeanApp[
                   LeanLink`LeanConst["instHMul", {
                    LeanLink`LeanLevelParam["u"]}], 
                   LeanLink`LeanBVar[2]], 
                  LeanLink`LeanApp[
                   LeanLink`LeanApp[
                    LeanLink`LeanConst["MulOne.toMul", {
                    LeanLink`LeanLevelParam["u"]}], 
                    LeanLink`LeanBVar[2]], 
                   LeanLink`LeanApp[
