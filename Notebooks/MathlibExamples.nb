Cell["Part 1: Types and Propositions", "Chapter",ExpressionUUID->"9781a64a-2134-429a-aeb9-cbde6b5b44f1"],

Cell[TextData[{
 "In Lean 4 (and Mathlib), every expression has a ",
 StyleBox["type",
  FontSlant->Italic],
 ". Propositions live in ",
 Cell["Prop", "InlineCode",ExpressionUUID->
  "231da61a-061c-46fd-a13b-d258eea88b4f"],
 ", data types live in ",
 Cell["Type u", "InlineCode",ExpressionUUID->
  "0937b7a7-dda3-4837-8032-59dc8934a238"],
 ". LeanLink lets us inspect these directly."
}], "Text",ExpressionUUID->"623a35ac-144b-4543-b34f-4a651113d9fa"],

