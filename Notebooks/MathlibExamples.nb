Cell[TextData[{
 "The output tells us: to use ",
 Cell["mul_comm", "InlineCode",ExpressionUUID->
  "6f06d607-151d-4db8-a546-cf61b155efc6"],
 ", we provide two explicit values ",
 Cell["a", "InlineCode",ExpressionUUID->
  "db419090-d60a-449c-9f66-f543612caa84"],
 " and ",
 Cell["b", "InlineCode",ExpressionUUID->
  "051b6805-a444-4a9d-933e-2e0c54dcefb3"],
 ", and Lean auto-resolves the type ",
 Cell["G", "InlineCode",ExpressionUUID->
  "518beeb2-406e-4107-9345-e675c5c86039"],
 " (implicit) and the ",
 Cell["CommMagma", "InlineCode",ExpressionUUID->
  "877e8d94-2288-4f4b-b261-d09f0b72a752"],
 " instance."
}], "Text",ExpressionUUID->"4aed278e-fdfa-4b5d-b7bd-c1c6b7ba8b62"],

