Cell[TextData[{
 "Every Lean expression is built from a small set of constructors: ",
 Cell["LeanConst", "InlineCode",ExpressionUUID->
  "b9227045-a709-4155-bece-0f76039497f7"],
 " (named constant), ",
 Cell["LeanApp", "InlineCode",ExpressionUUID->
  "faaa55b4-a97f-473a-8982-e8997c30b43b"],
 " (function application), ",
 Cell["LeanForall", "InlineCode",ExpressionUUID->
  "c8e9d2b9-ada5-4c07-8a23-216f80475073"],
 " (universal quantifier / function type), ",
 Cell["LeanBVar", "InlineCode",ExpressionUUID->
  "fa76c4d0-dd0d-4e7a-a475-7e9aabda00cf"],
 " (bound variable), ",
 Cell["LeanLambda", "InlineCode",ExpressionUUID->
  "05fb204f-91b9-4c43-8702-9dbc3eb76c33"],
 ", and ",
 Cell["LeanSort", "InlineCode",ExpressionUUID->
  "a02754af-257d-4835-ac90-b35380738a54"],
 "."
}], "Text",ExpressionUUID->"5317ac35-6ab7-4395-8faf-65df3c2502b7"],

Cell["Part 2: Understanding Binder Annotations", "Chapter",ExpressionUUID->"bf6d077d-b12d-409f-9ba6-c94340ea0bb0"],

Cell["Lean uses three kinds of argument brackets:", "Text",ExpressionUUID->"d1257ca5-b435-42f1-840c-f5bfc96e277e"],

Cell[TextData[{
 Cell["(x : T)", "InlineCode",ExpressionUUID->
  "9730a022-4dc7-4b03-add9-3da3704efc2a"],
 " \[LongDash] ",
 StyleBox["explicit",
  FontWeight->Bold],
 ": the caller must provide this"
}], "Item",ExpressionUUID->"49ed5a29-79a7-4b0b-9436-f0e4e7314b13"],

Cell[TextData[{
 Cell["{x : T}", "InlineCode",ExpressionUUID->
  "2166ebdb-4e46-4b95-a641-7496bf4ba35a"],
 " \[LongDash] ",
 StyleBox["implicit",
  FontWeight->Bold],
 ": Lean infers this from context"
}], "Item",ExpressionUUID->"20df87d4-7c12-44bc-8fb0-5cae04f8f6e4"],

Cell[TextData[{
 Cell["[inst : T]", "InlineCode",ExpressionUUID->
  "58e8613a-2c81-42da-a41c-09853a21369c"],
 " \[LongDash] ",
 StyleBox["instance",
  FontWeight->Bold],
 ": Lean finds this via typeclass search"
}], "Item",ExpressionUUID->"a4d288d2-7a9f-4292-8703-6db66c6981f5"],

Cell[TextData[{
 "The new ",
 Cell["\"Parameters\"", "InlineCode",ExpressionUUID->
  "2e6ba0dd-b82f-43c8-8e40-1325f13128a6"],
 " property peels apart the forall chain and shows each argument:"
}], "Text",ExpressionUUID->"169c1eea-a1a4-4876-9dc7-a7150be4738d"],

