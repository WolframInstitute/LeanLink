Cell["Building a typeclass hierarchy", "Section",ExpressionUUID->"9b1ed788-175a-49f1-858b-3adf18c5d71f"],

Cell[TextData[{
 "Each typeclass extends others. An ",
 Cell["AddGroup", "InlineCode",ExpressionUUID->
  "2974f639-3abf-4205-8282-cbfaeb029cde"],
 " extends ",
 Cell["AddMonoid", "InlineCode",ExpressionUUID->
  "b693b990-9144-42aa-ade4-4a7c1ba25a42"],
 " extends ",
 Cell["AddZeroClass", "InlineCode",ExpressionUUID->
  "1924f983-eae9-4846-972c-f9ef58b0fb62"],
 ". We can see this by inspecting the type of the typeclass itself:"
}], "Text",ExpressionUUID->"6500825c-1a88-4c7e-924a-06d68c9bc069"],

