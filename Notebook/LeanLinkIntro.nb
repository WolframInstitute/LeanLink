Notebook[{
Cell["LeanLink", "Title",ExpressionUUID->"92cf67cb-638e-428b-b229-fef1fad56275"],

Cell["Explore Lean 4 proof structures from Wolfram Language.", "Text",ExpressionUUID->"5ae54e1e-79d0-4795-88c5-d44541d1d80e"],

Cell["Setup", "Chapter",ExpressionUUID->"0f0a5af8-584a-4985-9506-d2f721b97570"],

Cell[BoxData[
 RowBox[{"PacletInstall", "[", 
  RowBox[{"\"\<https://www.wolframcloud.com/obj/nikm/LeanLink.paclet\>\"", ",",
    " ", 
   RowBox[{"ForceVersionInstall", " ", "->", " ", "True"}]}], "]"}]], "Input",\
ExpressionUUID->"3993dcac-8eb3-41f2-b06a-3c6787d19244"],

Cell[BoxData[
 RowBox[{"<<", " ", "LeanLink`"}]], "Input",ExpressionUUID->"d374bebc-6178-4fe6-af76-e5433ef162aa"],

Cell["Quick Start", "Chapter",ExpressionUUID->"66e39386-4711-485c-9a5b-89b1ac577c3f"],

Cell["\<\
LeanLink ships with built-in examples: textbook proofs and dependent types.\
\>", "Text",ExpressionUUID->"11586cc5-067a-46a4-ae7b-4a76842af8fb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"nativeDir", " ", "=", " ", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"PacletObject", "[", "\"\<LeanLink\>\"", "]"}], 
       "[", "\"\<Location\>\"", "]"}], ",", " ", "\"\<Native\>\""}], "}"}], 
    "]"}]}], ";"}]], "Input",ExpressionUUID->"0ccec481-5e5c-48df-8dd6-\
e1b96aa39635"],

Cell["Import from a .lean file", "Section",ExpressionUUID->"45606475-50d6-4611-be20-012722d0ffc6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"exFile", " ", "=", " ", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
     "nativeDir", ",", " ", "\"\<lib\>\"", ",", " ", "\"\<LeanLink\>\"", ",", 
      " ", "\"\<Examples.lean\>\""}], "}"}], "]"}]}], ";"}]], "Input",Expressi\
onUUID->"1953e47f-8ee3-4875-b274-146006b0af2f"],

Cell[BoxData[
 RowBox[{"env", " ", "=", " ", 
  RowBox[{"LeanImport", "[", 
   RowBox[{"exFile", ",", " ", 
    RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "nativeDir"}]}], 
   "]"}]}]], "Input",ExpressionUUID->"9785f83b-ed74-4788-bf64-e075f29e234b"],

Cell["Browse Constants", "Section",ExpressionUUID->"fd46c152-75a8-441d-9f07-de5ca1edd4ac"],

Cell["\<\
Internal names are filtered \[LongDash] only top-level theorems, definitions, \
and inductives show:\
\>", "Text",ExpressionUUID->"83673185-fa1e-435f-ba69-a9f9c0c8fa18"],

Cell[BoxData[
 RowBox[{"Keys", "[", "env", "]"}]], "Input",ExpressionUUID->"8811815a-19b9-4ecc-b2dc-e0a5d644f4fb"],

Cell["Typed Objects", "Section",ExpressionUUID->"87885888-9639-4b55-a956-a480b719eb62"],

Cell[TextData[{
 "Each value is a ",
 Cell["LeanTerm", "InlineCode",ExpressionUUID->
  "c5469644-ecf6-43e4-8559-9f6adba641ff"],
 " with its kind shown in a colored summary:"
}], "Text",ExpressionUUID->"e78ee54d-07dc-4b54-841d-a0e7b3cf49a5"],

Cell[BoxData[
 RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}]], "Input",Exp\
ressionUUID->"b416e471-a3fc-473b-8666-ad3b040fe4b7"],

Cell[BoxData[
 RowBox[{"env", "[", "\"\<LeanLink.Examples.Vec\>\"", "]"}]], "Input",Expressi\
onUUID->"7f9e7bff-1216-4ea7-b107-40937ad62eec"],

Cell[BoxData[
 RowBox[{"env", "[", "\"\<LeanLink.Examples.Vec.head\>\"", "]"}]], "Input",Exp\
ressionUUID->"4261af95-fb7e-41cc-bd03-911d623238b3"],

Cell["Property Access", "Section",ExpressionUUID->"3a863948-d749-4d80-a96a-b43a7cf5f562"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}], 
  "[", "\"\<Kind\>\"", "]"}]], "Input",ExpressionUUID->"9c23dfa0-d661-4a95-\
98f0-074574bbf9be"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}], 
  "[", "\"\<Type\>\"", "]"}]], "Input",ExpressionUUID->"f87badd2-9390-4136-\
8fe9-50e4d161004a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}], 
  "[", "\"\<Term\>\"", "]"}]], "Input",ExpressionUUID->"f44a477a-376a-4c67-\
abd6-6d509711ad89"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}], 
  "[", "\"\<Properties\>\"", "]"}]], "Input",ExpressionUUID->"e17d12c8-c9b0-\
492a-b374-2e5ed1d72f64"],

Cell["Expression Graph", "Section",ExpressionUUID->"2cc13917-27d5-4d43-9494-7265ecf44bdb"],

Cell["\<\
Visualize the type as a tree \[LongDash] nodes are colored by head: blue for \
\[ForAll], purple for \[Lambda], green for constants.\
\>", "Text",ExpressionUUID->"5a94b6c8-9a7f-4c44-b27d-4f86c875ab07"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.modus_ponens\>\"", "]"}], 
  "[", "\"\<ExprGraph\>\"", "]"}]], "Input",ExpressionUUID->"bc0adac3-d56f-\
4247-a1ee-2b5a409fe5df"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.Vec.map\>\"", "]"}], 
  "[", "\"\<ExprGraph\>\"", "]"}]], "Input",ExpressionUUID->"ebff0e39-c02e-\
4ec5-9178-dd97b4671a32"],

Cell["Call Graph", "Section",ExpressionUUID->"f990850b-1042-41e9-bf33-b832effd36b3"],

Cell["See which constants a proof depends on:", "Text",ExpressionUUID->"41af8102-428b-40f4-b9c2-bd33982b51e9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.contrapositive\>\"", "]"}], 
  "[", "\"\<CallGraph\>\"", "]"}]], "Input",ExpressionUUID->"0e558540-8e8e-\
4811-8058-1001de024c1a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.add_zero\>\"", "]"}], 
  "[", "\"\<CallGraph\>\"", "]"}]], "Input",ExpressionUUID->"7d447aae-c103-\
425f-996c-417b615df03e"],

Cell["Low-Level API", "Chapter",ExpressionUUID->"70a7b957-375a-4288-9592-a3a9919b2195"],

Cell["Query individual constants without importing everything:", "Text",ExpressionUUID->"199a3e01-c1dc-456b-862b-908da2e91799"],

Cell[BoxData[
 RowBox[{"LeanExpr", "[", 
  RowBox[{"\"\<LeanLink.Examples.modus_ponens\>\"", ",", " ", 
   RowBox[{"\"\<Imports\>\"", " ", "->", " ", 
    RowBox[{"{", "\"\<LeanLink\>\"", "}"}]}], ",", " ", 
   RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "nativeDir"}]}], 
  "]"}]], "Input",ExpressionUUID->"44669925-51c5-42df-b8ea-dbbaa4adef9f"],

Cell[BoxData[
 RowBox[{"LeanValue", "[", 
  RowBox[{"\"\<LeanLink.Examples.identity\>\"", ",", " ", 
   RowBox[{"\"\<Imports\>\"", " ", "->", " ", 
    RowBox[{"{", "\"\<LeanLink\>\"", "}"}]}], ",", " ", 
   RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "nativeDir"}], ",", " ", 
   RowBox[{"\"\<Depth\>\"", " ", "->", " ", "10"}]}], "]"}]], "Input",Expressi\
onUUID->"556fd0ba-c39f-428f-8b30-5b2dcb888aef"],

Cell["TM {2,2} Rule 445 \[LongDash] Successor Proof", "Chapter",ExpressionUUID->"58622b5e-39b7-43b6-a7b3-7db17e9e7ff4"],

Cell["\<\
The TuringMachineSearch project proves that the {2,2} Turing machine rule 445 \
computes the successor function:\
\>", "Text",ExpressionUUID->"cca9b466-a40c-45b0-9b92-79c1d5036324"],

Cell[BoxData[
 RowBox[{"projectDir", " ", "=", " ", 
  RowBox[{"ParentDirectory", "[", 
   RowBox[{
    RowBox[{"NotebookDirectory", "[", "]"}], ",", " ", "2"}], 
   "]"}]}]], "Input",ExpressionUUID->"9e56f289-a40a-43c6-b142-d513315d9949"],

Cell[BoxData[
 RowBox[{"tm", " ", "=", " ", 
  RowBox[{"LeanImport", "[", 
   RowBox[{"\"\<OneSidedTM\>\"", ",", " ", 
    RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "projectDir"}], ",", " ", 
    RowBox[{"\"\<Filter\>\"", " ", "->", " ", "\"\<rule445\>\""}]}], 
   "]"}]}]], "Input",ExpressionUUID->"e85371cd-6a2d-4bfd-a831-3efd3d0c7724"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tm", "[", "\"\<OneSidedTM.rule445_computesSucc\>\"", "]"}], 
  "[", "\"\<ExprGraph\>\"", "]"}]], "Input",ExpressionUUID->"c8f75c2c-e8d8-\
47d4-8814-37550c05b446"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tm", "[", "\"\<OneSidedTM.rule445_computesSucc\>\"", "]"}], 
  "[", "\"\<CallGraph\>\"", "]"}]], "Input",ExpressionUUID->"b6f1fa6c-5f31-\
47a0-86cd-7cdf1232f7bc"]
},
