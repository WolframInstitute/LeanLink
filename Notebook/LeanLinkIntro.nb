Notebook[{
Cell["LeanLink", "Title",ExpressionUUID->"e291eba5-cf86-474a-ab07-aaaed365b03a"],

Cell["Explore Lean 4 proof structures from Wolfram Language.", "Text",ExpressionUUID->"78d0cb34-a090-4e3c-8a8e-8b4d92c95d3e"],

Cell["Setup", "Chapter",ExpressionUUID->"dd179e7c-52c7-4a66-ae94-b14c86c0da9f"],

Cell[BoxData[
 RowBox[{"PacletInstall", "[", 
  RowBox[{"\"\<https://www.wolframcloud.com/obj/nikm/LeanLink.paclet\>\"", ",",
    " ", 
   RowBox[{"ForceVersionInstall", " ", "->", " ", "True"}]}], "]"}]], "Input",\
ExpressionUUID->"2f7dc39d-fc35-4e72-b708-230a0eceb6ce"],

Cell[BoxData[
 RowBox[{"<<", " ", "LeanLink`"}]], "Input",ExpressionUUID->"02d779ee-cb9b-440c-81a4-46b9d94f26da"],

Cell["Quick Start", "Chapter",ExpressionUUID->"96eb9e05-ff10-40b5-817e-0d29e33b317d"],

Cell["\<\
LeanLink ships with built-in examples: textbook proofs and dependent types.\
\>", "Text",ExpressionUUID->"0d5eb721-cb88-4291-ba75-e995f5ee5791"],

Cell["Import a standalone .lean file", "Section",ExpressionUUID->"772bee63-2877-4dc6-8ed5-8b5d196d7922"],

Cell[BoxData[
 RowBox[{"exFile", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"PacletFind", "[", "\"\<LeanLink\>\"", "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}], "[", 
   RowBox[{"\"\<AssetLocation\>\"", ",", " ", "\"\<Examples\>\""}], 
   "]"}]}]], "Input",ExpressionUUID->"6867bca6-ac84-4ff7-90e7-7d1caecca524"],

Cell[BoxData[
 RowBox[{"env", " ", "=", " ", 
  RowBox[{"LeanImport", "[", "exFile", "]"}]}]], "Input",ExpressionUUID->\
"dc02eff1-3fef-4593-a89d-ad2bc7b1e822"],

Cell["Browse Constants", "Section",ExpressionUUID->"f47e887e-4b4a-455a-a441-a761fac2dcf9"],

Cell["\<\
Internal names are filtered \[LongDash] only top-level theorems, definitions, \
and inductives show:\
\>", "Text",ExpressionUUID->"3000337b-eae8-4b8a-904c-aba9dc1e7cdf"],

Cell[BoxData[
 RowBox[{"Keys", "[", "env", "]"}]], "Input",ExpressionUUID->"cf0f34f6-cedd-487d-b06c-037d8d8f7a7c"],

Cell["Typed Objects", "Section",ExpressionUUID->"9854e976-f150-486d-8034-5bdb42f952fe"],

Cell[TextData[{
 "Each value is a ",
 Cell["LeanTerm", "InlineCode",ExpressionUUID->
  "40a6d748-885c-43c1-a27c-5fedc9809540"],
 " with its kind shown in a colored summary:"
}], "Text",ExpressionUUID->"24097ace-24cf-4f4b-b7bb-814bf3913798"],

Cell[BoxData[
 RowBox[{"env", "[", "\"\<id_proof\>\"", "]"}]], "Input",ExpressionUUID->"ae74e370-24de-44a8-a527-55480221d398"],

Cell[BoxData[
 RowBox[{"env", "[", "\"\<Vec\>\"", "]"}]], "Input",ExpressionUUID->"2980a201-0324-498e-ae3c-79dcc69874c1"],

Cell[BoxData[
 RowBox[{"env", "[", "\"\<Vec.head\>\"", "]"}]], "Input",ExpressionUUID->"f7c22650-6cf5-47cc-b936-2d659f631396"],

Cell["Property Access", "Section",ExpressionUUID->"f34feca1-c12f-4b99-8adc-9c07268a717b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<id_proof\>\"", "]"}], "[", "\"\<Kind\>\"", 
  "]"}]], "Input",ExpressionUUID->"1904e783-a6bf-4bdc-abec-4674310a320b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<id_proof\>\"", "]"}], "[", "\"\<Type\>\"", 
  "]"}]], "Input",ExpressionUUID->"3813b16e-2e2a-491b-9b47-c70d83bc520b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<id_proof\>\"", "]"}], "[", "\"\<Term\>\"", 
  "]"}]], "Input",ExpressionUUID->"af3760a6-13a7-4ced-8eba-25488492394e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<id_proof\>\"", "]"}], "[", "\"\<Properties\>\"", 
  "]"}]], "Input",ExpressionUUID->"a0c547a1-9c65-4405-9dec-a8d66c098ddf"],

Cell["Expression Graph", "Section",ExpressionUUID->"3eab2627-11ef-4243-b5a2-6334a3870d92"],

Cell["\<\
Visualize the type as a tree \[LongDash] nodes are colored by head: blue for \
\[ForAll], purple for \[Lambda], green for constants.\
\>", "Text",ExpressionUUID->"bfbac581-a7cf-447e-90db-d4929f15bb2d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<modus_ponens\>\"", "]"}], "[", "\"\<ExprGraph\>\"",
   "]"}]], "Input",ExpressionUUID->"aa57f49e-f41e-48f5-95ec-13ae9f2ae2de"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<Vec.map\>\"", "]"}], "[", "\"\<ExprGraph\>\"", 
  "]"}]], "Input",ExpressionUUID->"4aab6e6e-50cb-4c73-8c7b-20bfd2b171b4"],

Cell["Call Graph", "Section",ExpressionUUID->"593f7b12-5434-43e2-8696-f583dd4645a1"],

Cell["See which constants a proof depends on:", "Text",ExpressionUUID->"624f0015-8ae8-472d-974d-744036e50dc6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<contrapositive\>\"", "]"}], 
  "[", "\"\<CallGraph\>\"", "]"}]], "Input",ExpressionUUID->"c3817a29-7eef-\
4f99-b68a-845206850c98"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<zero_add_proof\>\"", "]"}], 
  "[", "\"\<CallGraph\>\"", "]"}]], "Input",ExpressionUUID->"c52d3019-0732-\
440e-8a18-d28ec99ec7e0"],

Cell["Module Import", "Chapter",ExpressionUUID->"d0fa15a9-ce36-466b-b695-6195cbd2e4be"],

Cell[TextData[{
 "Import from a Lake project with compiled ",
 Cell[".olean", "InlineCode",ExpressionUUID->
  "550657cb-08c2-4d64-8122-2b17e02bf552"],
 " files:"
}], "Text",ExpressionUUID->"8ce90767-e872-462f-8dc1-d717d9d0ceef"],

Cell[BoxData[
 RowBox[{
  RowBox[{"nativeDir", " ", "=", " ", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"PacletObject", "[", "\"\<LeanLink\>\"", "]"}], 
       "[", "\"\<Location\>\"", "]"}], ",", " ", "\"\<Native\>\""}], "}"}], 
    "]"}]}], ";"}]], "Input",ExpressionUUID->"c65053f0-2e51-44f7-8778-\
410eece44922"],

Cell[BoxData[
 RowBox[{"env2", " ", "=", " ", 
  RowBox[{"LeanImport", "[", 
   RowBox[{"\"\<LeanLink.Examples\>\"", ",", " ", 
    RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "nativeDir"}]}], 
   "]"}]}]], "Input",ExpressionUUID->"b256460a-9d8e-4238-a9a5-131606bb06e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env2", "[", "\"\<LeanLink.Examples.modus_ponens\>\"", "]"}], 
  "[", "\"\<ExprGraph\>\"", "]"}]], "Input",ExpressionUUID->"1eb10924-387e-\
4e91-9464-18c01a6256ca"],

Cell["Low-Level API", "Chapter",ExpressionUUID->"580a1025-f1c1-446c-b58e-32cd90d16a54"],

Cell["Query individual constants without importing everything:", "Text",ExpressionUUID->"d1869211-876d-4ef3-bac7-6b5293b2f246"],

Cell[BoxData[
 RowBox[{"LeanExpr", "[", 
  RowBox[{"\"\<LeanLink.Examples.modus_ponens\>\"", ",", " ", 
   RowBox[{"\"\<Imports\>\"", " ", "->", " ", 
    RowBox[{"{", "\"\<LeanLink\>\"", "}"}]}], ",", " ", 
   RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "nativeDir"}]}], 
  "]"}]], "Input",ExpressionUUID->"efa57127-725b-43fb-9eda-486b865dac00"],

Cell[BoxData[
 RowBox[{"LeanValue", "[", 
  RowBox[{"\"\<LeanLink.Examples.identity\>\"", ",", " ", 
   RowBox[{"\"\<Imports\>\"", " ", "->", " ", 
    RowBox[{"{", "\"\<LeanLink\>\"", "}"}]}], ",", " ", 
   RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "nativeDir"}], ",", " ", 
   RowBox[{"\"\<Depth\>\"", " ", "->", " ", "10"}]}], "]"}]], "Input",Expressi\
onUUID->"4c4f1645-3bc5-488d-abac-4763fca93e67"],

Cell["TM {2,2} Rule 445 \[LongDash] Successor Proof", "Chapter",ExpressionUUID->"91037c0e-9d1d-447e-b649-ecad668cb25e"],

Cell["\<\
The TuringMachineSearch project proves that the {2,2} Turing machine rule 445 \
computes the successor function:\
\>", "Text",ExpressionUUID->"1c60b4b3-51c3-4dc8-ad04-7eaf2feb8fa2"],

Cell[BoxData[
 RowBox[{"projectDir", " ", "=", " ", 
  RowBox[{"ParentDirectory", "[", 
   RowBox[{
    RowBox[{"NotebookDirectory", "[", "]"}], ",", " ", "2"}], 
   "]"}]}]], "Input",ExpressionUUID->"91057d10-3536-4331-8289-39b7a69ac069"],

Cell[BoxData[
 RowBox[{"tm", " ", "=", " ", 
  RowBox[{"LeanImport", "[", 
   RowBox[{"\"\<OneSidedTM\>\"", ",", " ", 
    RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "projectDir"}], ",", " ", 
    RowBox[{"\"\<Filter\>\"", " ", "->", " ", "\"\<rule445\>\""}]}], 
   "]"}]}]], "Input",ExpressionUUID->"fb86b051-2d65-44ac-aac6-544028db947f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tm", "[", "\"\<OneSidedTM.rule445_computesSucc\>\"", "]"}], 
  "[", "\"\<ExprGraph\>\"", "]"}]], "Input",ExpressionUUID->"9f36c556-1613-\
4483-b0eb-2fe85735634e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tm", "[", "\"\<OneSidedTM.rule445_computesSucc\>\"", "]"}], 
  "[", "\"\<CallGraph\>\"", "]"}]], "Input",ExpressionUUID->"928688d8-c05f-\
4c79-92a9-e76490f9703a"]
},
