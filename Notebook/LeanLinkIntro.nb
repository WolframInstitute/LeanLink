Cell[CellGroupData[{

Cell["Constructing Expressions & Type-Checking", "Chapter",ExpressionUUID->"45da83d3-5baa-4575-a838-b6a12e5d44d0"],

Cell["\<\
Build Lean expressions from WL heads and type-check them against the \
environment:\
\>", "Text",ExpressionUUID->"c5779c7b-afc6-48d5-82e5-c0a2786f83c2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"expr", " ", "=", " ", 
   RowBox[{"LeanApp", "[", 
    RowBox[{
     RowBox[{"LeanConst", "[", 
      RowBox[{"\"\<Nat.succ\>\"", ",", " ", 
       RowBox[{"{", "}"}]}], "]"}], ",", " ", 
     RowBox[{"LeanLitNat", "[", "42", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"LeanTypeCheck", "[", 
  RowBox[{"expr", ",", " ", "env"}], "]"}]}], "Input",
 CellLabel->"In[11]:=",ExpressionUUID->"7b4d1b1e-0d5c-4ef3-a112-df10eab639df"],

