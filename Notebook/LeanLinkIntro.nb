Cell[CellGroupData[{

Cell["Interactive Tactic Proofs", "Chapter",ExpressionUUID->"aa63bf66-ee7a-4dde-b70e-971a700f8241"],

Cell["\<\
Open a proof goal for a theorem and step through it interactively:\
\>", "Text",ExpressionUUID->"82ad8c07-602b-40bd-b114-3edea2bdd55a"],

Cell[CellGroupData[{

Cell["Example 1: Identity (\[ForAll] P : Prop, P \[RightArrow] P)", "Section",ExpressionUUID->"46e0b1f9-c846-4a5e-94d7-3ac644ccbd03"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s0", " ", "=", " ", 
   RowBox[{"LeanOpenGoal", "[", 
    RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s0", "]"}]}], "Input",ExpressionUUID->\
"4ca0a99c-d43f-4714-aa35-69db4b78966b"],

Cell["Introduce the proposition P:", "Text",ExpressionUUID->"614ffa39-3ab5-4f8b-a26b-aa183e11ea55"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s1", " ", "=", " ", 
   RowBox[{"LeanApplyTactic", "[", 
    RowBox[{
     RowBox[{"s0", "[", "\"\<stateId\>\"", "]"}], ",", 
     " ", "\"\<intro P\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s1", "]"}]}], "Input",ExpressionUUID->\
"f43ecec5-be1f-4685-abc7-af19fcff2e0e"],

Cell["Introduce the hypothesis h : P:", "Text",ExpressionUUID->"ea4bda9b-8344-4d04-904c-6817f4eb5265"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s2", " ", "=", " ", 
   RowBox[{"LeanApplyTactic", "[", 
    RowBox[{
     RowBox[{"s1", "[", "\"\<stateId\>\"", "]"}], ",", 
     " ", "\"\<intro h\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s2", "]"}]}], "Input",ExpressionUUID->\
"2f7f5d40-bab8-41cf-bb32-4e68f0dce7a2"],

Cell["Close the goal \[LongDash] h is exactly what we need:", "Text",ExpressionUUID->"684ffa7c-1723-4c39-8a67-dc2aa51f990c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s3", " ", "=", " ", 
   RowBox[{"LeanApplyTactic", "[", 
    RowBox[{
     RowBox[{"s2", "[", "\"\<stateId\>\"", "]"}], ",", 
     " ", "\"\<exact h\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s3", "]"}]}], "Input",ExpressionUUID->\
"03f2747a-3397-455f-974e-181d6d6c8f9e"]
}, Open  ]],

