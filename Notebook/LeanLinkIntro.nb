Cell[CellGroupData[{

Cell["Example 4: Piping Tactics", "Section",ExpressionUUID->"8cf3703d-9026-4c8a-8c7f-d5932ad44723"],

Cell["Apply multiple tactics in one call:", "Text",ExpressionUUID->"5e58fc16-b04b-447e-9d38-90ab110a3c8f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s0", " ", "=", " ", 
   RowBox[{"LeanOpenGoal", "[", 
    RowBox[{"env", "[", "\"\<LeanLink.Examples.and_comm\>\"", "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s0", "]"}]}], "Input",ExpressionUUID->\
"2e48bd1e-65c8-4c86-b848-0872aee8a523"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"sf", " ", "=", " ", 
   RowBox[{"LeanApplyTactic", "[", 
    RowBox[{
     RowBox[{"s0", "[", "\"\<stateId\>\"", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<intro h\>\"", ",", 
       " ", "\"\<exact \[LeftAngleBracket]h.2, h.1\[RightAngleBracket]\>\""}],
