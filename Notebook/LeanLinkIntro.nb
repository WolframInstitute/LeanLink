Notebook[{
Cell["LeanLink \[LongDash] Interactive Lean from Wolfram Language", "Title",ExpressionUUID->"419a5e5a-964d-4a15-bd1d-9bd2df35bc8c"],

Cell["Setup", "Chapter",ExpressionUUID->"b3028b04-da32-4f64-9358-027ac2395ad2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"PacletDirectoryLoad", "[", 
   RowBox[{
    RowBox[{"NotebookDirectory", "[", "]"}], " ", "//", " ", 
    "ParentDirectory"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Needs", "[", "\"\<LeanLink`\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"nativeDir", " ", "=", " ", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"PacletObject", "[", "\"\<LeanLink\>\"", "]"}], 
       "[", "\"\<Location\>\"", "]"}], ",", " ", "\"\<Native\>\""}], "}"}], 
    "]"}]}], ";"}]}], "Input",ExpressionUUID->"35461c7a-edb6-402a-a558-\
b72156c46384"],

Cell["Importing a Lean Environment", "Chapter",ExpressionUUID->"1f6e28e3-3ecd-4b8d-a90a-d75bdb1053e3"],

Cell[BoxData[
 RowBox[{"env", " ", "=", " ", 
  RowBox[{"LeanImport", "[", 
   RowBox[{"\"\<LeanLink.Examples\>\"", ",", "\n", "  ", 
    RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "nativeDir"}], ",", "\n", 
    "  ", 
    RowBox[{"\"\<Imports\>\"", " ", "->", " ", 
     RowBox[{"{", "\"\<LeanLink\>\"", "}"}]}], ",", "\n", "  ", 
    RowBox[{"\"\<Filter\>\"", " ", "->", " ", "\"\<Examples\>\""}]}], 
   "]"}]}]], "Input",ExpressionUUID->"b85c7ed4-5f3a-4946-a79c-e079644ff455"],

Cell[BoxData[
 RowBox[{"Keys", "[", "env", "]"}]], "Input",ExpressionUUID->"ec8d1c4d-4d72-4936-8e79-b5a989470e33"],

Cell["Inspecting Types and Terms", "Chapter",ExpressionUUID->"37df9bb0-68cc-44c4-adce-7b083e5071f8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}], 
  "[", "\"\<TypeForm\>\"", "]"}]], "Input",ExpressionUUID->"7981646a-5e4c-\
49d0-af49-ff5b9feba72b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}], 
  "[", "\"\<Type\>\"", "]"}]], "Input",ExpressionUUID->"6d09a49f-f545-4653-\
91e3-0931bd196814"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.Vec.head\>\"", "]"}], "[", 
  RowBox[{"\"\<TypeForm\>\"", ",", " ", "1"}], "]"}]], "Input",ExpressionUUID->\
"457c9c37-9bc7-4019-9c98-0bda0695da72"],

Cell["Expression Graphs", "Chapter",ExpressionUUID->"7af18678-dafd-46f9-a31b-37f855477c38"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.modus_ponens\>\"", "]"}], 
  "[", "\"\<ExprGraph\>\"", "]"}]], "Input",ExpressionUUID->"30799153-3bfc-\
480c-b2fc-9e8f79d18723"],

Cell["Constructing Expressions", "Chapter",ExpressionUUID->"c82e92ea-cd87-4a35-842d-936f505924c8"],

Cell["\<\
Build a Lean expression and bind it to an environment for type-checking:\
\>", "Text",ExpressionUUID->"04c19052-e392-4219-9e9f-93fdc47c9edd"],

Cell[BoxData[
 RowBox[{"LeanTerm", "[", 
  RowBox[{
   RowBox[{"LeanApp", "[", 
    RowBox[{
     RowBox[{"LeanConst", "[", 
      RowBox[{"\"\<Nat.succ\>\"", ",", " ", 
       RowBox[{"{", "}"}]}], "]"}], ",", " ", 
     RowBox[{"LeanLitNat", "[", "42", "]"}]}], "]"}], ",", " ", "env"}], 
  "]"}]], "Input",ExpressionUUID->"728aafd7-044a-44a0-8015-e7fa67dbcb80"],

Cell[BoxData[
 RowBox[{"%", "[", "\"\<TypeForm\>\"", "]"}]], "Input",ExpressionUUID->"39ee4388-67ff-4af6-9fcc-dcd89a3f629f"],

Cell["Interactive Tactic Proofs", "Chapter",ExpressionUUID->"e3d6d884-fd31-449c-813e-e8fddb5dd92c"],

Cell[TextData[{
 "Identity: ",
 Cell[BoxData[Cell[TextData[{
   Cell[BoxData[
    FormBox[
     RowBox[{"\[ForAll]", 
      StyleBox["P", "TI"], 
      RowBox[{
       RowBox[{":", "Prop"}], ",", " "}], 
      StyleBox["P", "TI"], "\[Rule]", 
      StyleBox["P", "TI"]}], TraditionalForm]], "InlineFormula",
    ExpressionUUID->"a16697b1-c2dd-4593-921a-39b7b2109c20"],
   "  "
  }], "DisplayFormula",ExpressionUUID->
   "1e49b51f-134d-463a-aad6-96476d1f9785"]],ExpressionUUID->
  "528a4600-a9d2-407e-882b-ce72f82f41a6"]
}], "Section",ExpressionUUID->"8fc7ca91-8aca-446b-9c6c-564543fa4f06"],

Cell[BoxData[
 RowBox[{"s0", " ", "=", " ", 
  RowBox[{"LeanState", "[", 
   RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}], 
   "]"}]}]], "Input",ExpressionUUID->"ada70f2a-ba1a-4df7-aa4f-75da80b2f81b"],

Cell[BoxData[
 RowBox[{"s1", " ", "=", " ", 
  RowBox[{
   RowBox[{"LeanTactic", "[", "\"\<intro P\>\"", "]"}], "[", "s0", 
   "]"}]}]], "Input",ExpressionUUID->"07f14965-5e3a-49db-a908-6e2999e5d60b"],

Cell[BoxData[
 RowBox[{"s2", " ", "=", " ", 
  RowBox[{
   RowBox[{"LeanTactic", "[", "\"\<intro h\>\"", "]"}], "[", "s1", 
   "]"}]}]], "Input",ExpressionUUID->"6a38e352-5f12-4166-b1bd-b62f97972911"],

Cell[BoxData[
 RowBox[{"s3", " ", "=", " ", 
  RowBox[{
   RowBox[{"LeanTactic", "[", "\"\<exact h\>\"", "]"}], "[", "s2", 
   "]"}]}]], "Input",ExpressionUUID->"8cb5f2a5-05a5-43e1-a9f3-a0edb3ef106a"],

Cell[TextData[{
 "Modus Ponens: ",
 Cell[BoxData[Cell[TextData[{
   Cell[BoxData[
    FormBox[
     RowBox[{
      StyleBox["P", "TI"], "\[Rule]", 
      RowBox[{"(", 
       RowBox[{
        StyleBox["P", "TI"], "\[Rule]", 
        StyleBox["Q", "TI"]}], ")"}], "\[Rule]", 
      StyleBox["Q", "TI"]}], TraditionalForm]], "InlineFormula",
    ExpressionUUID->"4aa95b9e-48fd-4264-80ea-7fd161d08bd0"],
   "  "
  }], "DisplayFormula",ExpressionUUID->
   "e35e5425-f70b-49fd-b870-ef7ea1bd85f5"]],ExpressionUUID->
  "9143419e-48e5-4f27-a3fd-123a69f6d5c5"]
}], "Section",ExpressionUUID->"10543652-384e-43f6-affc-8a5d59a1eb90"],

Cell[BoxData[
 RowBox[{"s0", " ", "=", " ", 
  RowBox[{"LeanState", "[", 
   RowBox[{"env", "[", "\"\<LeanLink.Examples.modus_ponens\>\"", "]"}], 
   "]"}]}]], "Input",ExpressionUUID->"67f6afb9-f195-4877-bef3-362d5e506e34"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LeanTactic", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<intro P Q hP hPQ\>\"", ",", " ", "\"\<exact hPQ hP\>\""}], 
    "}"}], "]"}], "[", "s0", "]"}]], "Input",ExpressionUUID->"80e94f51-4d31-\
4593-983a-13f8f6dde768"],

Cell[TextData[{
 "And Commutativity: ",
 Cell[BoxData[Cell[TextData[{
   Cell[BoxData[
    FormBox[
     RowBox[{
      StyleBox["P", "TI"], "\[Wedge]", 
      StyleBox["Q", "TI"], "\[Rule]", 
      StyleBox["Q", "TI"], "\[Wedge]", 
      StyleBox["P", "TI"]}], TraditionalForm]], "InlineFormula",
    ExpressionUUID->"4dfab616-d9ac-40f7-9d93-3374b984f365"],
   "  "
  }], "DisplayFormula",ExpressionUUID->
   "918b3055-8ec1-404e-9861-94be7e580264"]],ExpressionUUID->
  "00c8f7ec-dabf-4bef-88ee-4855c16ee963"]
}], "Section",ExpressionUUID->"43cab9e1-516c-4a78-a763-4f74f785c8f7"],

Cell[BoxData[
 RowBox[{"s0", " ", "=", " ", 
  RowBox[{"LeanState", "[", 
   RowBox[{"env", "[", "\"\<LeanLink.Examples.and_comm\>\"", "]"}], 
   "]"}]}]], "Input",ExpressionUUID->"4902099a-7cde-4730-9382-a3b5c5659c81"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LeanTactic", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<intro P Q h\>\"", ",", 
     " ", "\"\<exact And.intro h.2 h.1\>\""}], "}"}], "]"}], "[", "s0", 
  "]"}]], "Input",ExpressionUUID->"418c9f19-7885-4c9d-9c05-6e641e370931"],

Cell["Accessing Goal Properties", "Section",ExpressionUUID->"b5cc7c32-ae25-46e8-8619-dc07130b356d"],

Cell[BoxData[{
 RowBox[{
