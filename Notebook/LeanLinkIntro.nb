Notebook[{
Cell["LeanLink \[LongDash] Interactive Lean from Wolfram Language", "Title",ExpressionUUID->"7917c8ad-dc39-4dfa-a578-39a22b384db6"],

Cell["Setup", "Chapter",ExpressionUUID->"f781a2ac-13a0-49a4-843a-aca7d76ff494"],

Cell["Load the paclet and point it at the Lean project:", "Text",ExpressionUUID->"0d97b888-cff1-418e-9295-ac8e8f76bd8a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"PacletDirectoryLoad", "[", 
   RowBox[{
    RowBox[{"NotebookDirectory", "[", "]"}], " ", "//", " ", 
    "ParentDirectory"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Needs", "[", "\"\<LeanLink`\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"nativeDir", " ", "=", " ", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"PacletObject", "[", "\"\<LeanLink\>\"", "]"}], 
       "[", "\"\<Location\>\"", "]"}], ",", " ", "\"\<Native\>\""}], "}"}], 
    "]"}]}], ";"}]}], "Input",ExpressionUUID->"664817d8-70b1-4a04-ba4c-\
da917623460e"],

Cell["Importing a Lean Environment", "Chapter",ExpressionUUID->"f34601c7-bab5-4c43-ac3b-9688c8eb1c25"],

Cell["\<\
Import constants from a Lean module. This is lazy \[LongDash] only names and \
kinds are loaded upfront:\
\>", "Text",ExpressionUUID->"c5f07615-8485-4b24-bf8e-2e26798c8872"],

Cell[BoxData[
 RowBox[{"env", " ", "=", " ", 
  RowBox[{"LeanImport", "[", 
   RowBox[{"\"\<LeanLink.Examples\>\"", ",", "\n", "  ", 
    RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "nativeDir"}], ",", "\n", 
    "  ", 
    RowBox[{"\"\<Imports\>\"", " ", "->", " ", 
     RowBox[{"{", "\"\<LeanLink\>\"", "}"}]}], ",", "\n", "  ", 
    RowBox[{"\"\<Filter\>\"", " ", "->", " ", "\"\<Examples\>\""}]}], 
   "]"}]}]], "Input",ExpressionUUID->"fb97d635-f193-47f5-bf2b-c120d49e65d3"],

Cell["List the available constants:", "Text",ExpressionUUID->"c6e85bae-dd3c-4a24-9c77-593c0eb66b95"],

Cell[BoxData[
 RowBox[{"Keys", "[", "env", "]"}]], "Input",ExpressionUUID->"5983bb6f-f233-4d66-b579-91654f200991"],

Cell["Inspecting Types and Terms", "Chapter",ExpressionUUID->"1741747d-fd88-4ab5-b7ab-cf9276352e56"],

Cell[TextData[{
 "Each entry is a ",
 Cell["LeanTerm", "InlineCode",ExpressionUUID->
  "a1669245-8bea-4269-9323-abf2d7637248"],
 ". Access its type (as an expression tree) or as a pretty-printed string:"
}], "Text",ExpressionUUID->"09da32bc-843a-4ef3-90d3-f37cd3883097"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}], 
  "[", "\"\<TypeForm\>\"", "]"}]], "Input",ExpressionUUID->"4dc915c8-53a4-\
4a01-a0a2-15c49f6b4f42"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}], 
  "[", "\"\<Type\>\"", "]"}]], "Input",ExpressionUUID->"7d21ed10-d949-4e89-\
8108-ad7fbebffb9e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}], 
  "[", "\"\<TermForm\>\"", "]"}]], "Input",ExpressionUUID->"3e6fc33f-1a91-\
4fc7-a9f9-57b15eb2161a"],

Cell["\<\
View the type with definitions unfolded (level 1 = unfold each definition \
once):\
\>", "Text",ExpressionUUID->"6f2b9133-5935-4b3f-9a91-5c31a5b8fed7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.Vec.head\>\"", "]"}], "[", 
  RowBox[{"\"\<TypeForm\>\"", ",", " ", "1"}], "]"}]], "Input",ExpressionUUID->\
"7bf7771a-9c1f-4af7-bc95-049d42c31833"],

Cell["Expression Graphs", "Chapter",ExpressionUUID->"cc3bc018-9fa4-4eb4-90d3-93703b305fb8"],

Cell["Visualize the structure of a definition as a graph:", "Text",ExpressionUUID->"bee9c7e4-6641-40e9-bd99-4439d40872e2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"env", "[", "\"\<LeanLink.Examples.modus_ponens\>\"", "]"}], 
  "[", "\"\<ExprGraph\>\"", "]"}]], "Input",ExpressionUUID->"37c3ac0f-4abd-\
4b6b-a5f6-676f686fe48b"],

Cell["Constructing Expressions & Type-Checking", "Chapter",ExpressionUUID->"45da83d3-5baa-4575-a838-b6a12e5d44d0"],

Cell["\<\
Build Lean expressions from WL heads and type-check them against the \
environment:\
\>", "Text",ExpressionUUID->"c5779c7b-afc6-48d5-82e5-c0a2786f83c2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"expr", " ", "=", " ", 
   RowBox[{"LeanApp", "[", 
    RowBox[{
     RowBox[{"LeanConst", "[", 
      RowBox[{"\"\<Nat.succ\>\"", ",", " ", 
       RowBox[{"{", "}"}]}], "]"}], ",", " ", 
     RowBox[{"LeanLitNat", "[", "42", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"LeanTypeCheck", "[", 
  RowBox[{"expr", ",", " ", "env"}], "]"}]}], "Input",ExpressionUUID->\
"7b4d1b1e-0d5c-4ef3-a112-df10eab639df"],

Cell[BoxData[
 RowBox[{"LeanTypeCheck", "[", 
  RowBox[{
   RowBox[{"LeanConst", "[", 
    RowBox[{"\"\<LeanLink.Examples.identity\>\"", ",", " ", 
     RowBox[{"{", "}"}]}], "]"}], ",", " ", "env"}], "]"}]], "Input",Expressio\
nUUID->"a3f88f0a-1eea-45b5-9395-edc0fdea2b1d"],

Cell["Interactive Tactic Proofs", "Chapter",ExpressionUUID->"aa63bf66-ee7a-4dde-b70e-971a700f8241"],

Cell["\<\
Open a proof goal for a theorem and step through it interactively:\
\>", "Text",ExpressionUUID->"82ad8c07-602b-40bd-b114-3edea2bdd55a"],

Cell["Example 1: Identity (\[ForAll] P : Prop, P \[RightArrow] P)", "Section",ExpressionUUID->"46e0b1f9-c846-4a5e-94d7-3ac644ccbd03"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s0", " ", "=", " ", 
   RowBox[{"LeanOpenGoal", "[", 
    RowBox[{"env", "[", "\"\<LeanLink.Examples.identity\>\"", "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s0", "]"}]}], "Input",ExpressionUUID->\
"4ca0a99c-d43f-4714-aa35-69db4b78966b"],

Cell["Introduce the proposition P:", "Text",ExpressionUUID->"614ffa39-3ab5-4f8b-a26b-aa183e11ea55"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s1", " ", "=", " ", 
   RowBox[{"LeanApplyTactic", "[", 
    RowBox[{
     RowBox[{"s0", "[", "\"\<stateId\>\"", "]"}], ",", 
     " ", "\"\<intro P\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s1", "]"}]}], "Input",ExpressionUUID->\
"f43ecec5-be1f-4685-abc7-af19fcff2e0e"],

Cell["Introduce the hypothesis h : P:", "Text",ExpressionUUID->"ea4bda9b-8344-4d04-904c-6817f4eb5265"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s2", " ", "=", " ", 
   RowBox[{"LeanApplyTactic", "[", 
    RowBox[{
     RowBox[{"s1", "[", "\"\<stateId\>\"", "]"}], ",", 
     " ", "\"\<intro h\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s2", "]"}]}], "Input",ExpressionUUID->\
"2f7f5d40-bab8-41cf-bb32-4e68f0dce7a2"],

Cell["Close the goal \[LongDash] h is exactly what we need:", "Text",ExpressionUUID->"684ffa7c-1723-4c39-8a67-dc2aa51f990c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s3", " ", "=", " ", 
   RowBox[{"LeanApplyTactic", "[", 
    RowBox[{
     RowBox[{"s2", "[", "\"\<stateId\>\"", "]"}], ",", 
     " ", "\"\<exact h\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s3", "]"}]}], "Input",ExpressionUUID->\
"03f2747a-3397-455f-974e-181d6d6c8f9e"],

Cell["Example 2: Modus Ponens (P \[RightArrow] (P \[RightArrow] Q) \
\[RightArrow] Q)", "Section",ExpressionUUID->"fb5ace37-8553-4c46-b28c-\
e194758727f7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s0", " ", "=", " ", 
   RowBox[{"LeanOpenGoal", "[", 
    RowBox[{"env", "[", "\"\<LeanLink.Examples.modus_ponens\>\"", "]"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s0", "]"}]}], "Input",ExpressionUUID->\
"ceb055f0-3040-441f-9d25-ffc10fbccb0a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s1", " ", "=", " ", 
   RowBox[{"LeanApplyTactic", "[", 
    RowBox[{
     RowBox[{"s0", "[", "\"\<stateId\>\"", "]"}], ",", 
     " ", "\"\<intro P Q hP hPQ\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s1", "]"}]}], "Input",ExpressionUUID->\
"2c5a9e69-a6e4-4777-8221-218fe33f865b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s2", " ", "=", " ", 
   RowBox[{"LeanApplyTactic", "[", 
    RowBox[{
     RowBox[{"s1", "[", "\"\<stateId\>\"", "]"}], ",", 
     " ", "\"\<exact hPQ hP\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s2", "]"}]}], "Input",ExpressionUUID->\
"6b6bf558-ed9e-4cf4-9276-c154acce0b64"],

Cell["Example 3: Contrapositive ((P \[RightArrow] Q) \[RightArrow] \[Not]Q \
\[RightArrow] \[Not]P)", "Section",ExpressionUUID->"2009e135-bb77-4010-a2e6-\
b09bfddd3443"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s0", " ", "=", " ", 
   RowBox[{"LeanOpenGoal", "[", 
    RowBox[{"env", "[", "\"\<LeanLink.Examples.contrapositive\>\"", "]"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s0", "]"}]}], "Input",ExpressionUUID->\
"63081829-7c3b-49b7-9e4e-878930718db8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s1", " ", "=", " ", 
   RowBox[{"LeanApplyTactic", "[", 
    RowBox[{
     RowBox[{"s0", "[", "\"\<stateId\>\"", "]"}], ",", 
     " ", "\"\<intro P Q hPQ hNQ hP\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s1", "]"}]}], "Input",ExpressionUUID->\
"5f5ecbb8-41fb-40b4-af70-8beb189c8dd1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s2", " ", "=", " ", 
   RowBox[{"LeanApplyTactic", "[", 
    RowBox[{
     RowBox[{"s1", "[", "\"\<stateId\>\"", "]"}], ",", 
     " ", "\"\<exact hNQ (hPQ hP)\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s2", "]"}]}], "Input",ExpressionUUID->\
"ebb00eb6-3fb8-4be2-bdd4-0ede2c1f9fbd"],

Cell["Example 4: Piping Tactics", "Section",ExpressionUUID->"8cf3703d-9026-4c8a-8c7f-d5932ad44723"],

Cell["Apply multiple tactics in one call:", "Text",ExpressionUUID->"5e58fc16-b04b-447e-9d38-90ab110a3c8f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"s0", " ", "=", " ", 
   RowBox[{"LeanOpenGoal", "[", 
    RowBox[{"env", "[", "\"\<LeanLink.Examples.and_comm\>\"", "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "s0", "]"}]}], "Input",ExpressionUUID->\
"2e48bd1e-65c8-4c86-b848-0872aee8a523"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"sf", " ", "=", " ", 
   RowBox[{"LeanApplyTactic", "[", 
    RowBox[{
     RowBox[{"s0", "[", "\"\<stateId\>\"", "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<intro h\>\"", ",", 
       " ", "\"\<exact \[LeftAngleBracket]h.2, h.1\[RightAngleBracket]\>\""}],
       "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"FormatLeanState", "[", "sf", "]"}]}], "Input",ExpressionUUID->\
"59ad4416-7253-4667-ad73-1fa534be49f6"]
},
