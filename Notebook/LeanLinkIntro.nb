Cell["Importing from Mathlib", "Chapter",ExpressionUUID->"befa62b4-19d5-434f-accc-c66ff68dd76a"],

Cell[TextData[{
 "LeanLink can import theorems from any Lean project. Point ",
 Cell["\"ProjectDir\"", "InlineCode",ExpressionUUID->
  "90eb8e09-5482-4c10-874c-b938ae3b9812"],
 " at a mathlib4 checkout where ",
 Cell["lake exe cache get && lake build Mathlib.Tactic.Ring", "InlineCode",
  ExpressionUUID->"ab24858b-e8b0-42cf-b7f5-3efc37964a7f"],
 " has been run:"
}], "Text",ExpressionUUID->"adbf8611-42d0-47bc-8b2c-193d71070110"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"mathlibDir", " ", "=", " ", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
     "$HomeDirectory", ",", " ", "\"\<src\>\"", ",", 
      " ", "\"\<mathlib4\>\""}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"DirectoryQ", "[", 
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{
      "mathlibDir", ",", " ", "\"\<.lake\>\"", ",", " ", "\"\<build\>\""}], 
      "}"}], "]"}], "]"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"mathEnv", " ", "=", " ", 
     RowBox[{"LeanImport", "[", 
      RowBox[{"\"\<Mathlib.Tactic.Ring\>\"", ",", "\n", "    ", 
       RowBox[{"\"\<ProjectDir\>\"", " ", "->", " ", "mathlibDir"}], ",", 
       "\n", "    ", 
       RowBox[{"\"\<Imports\>\"", " ", "->", " ", 
        RowBox[{"{", "\"\<Mathlib.Tactic.Ring\>\"", "}"}]}], ",", "\n", 
       "    ", 
       RowBox[{"\"\<Filter\>\"", " ", "->", " ", "\"\<Ring\>\""}]}], "]"}]}], 
    ";", "\n", "  ", 
    RowBox[{"Keys", "[", "mathEnv", "]"}]}], ",", "\n", 
   "  ", "\"\<Mathlib not built \[LongDash] run in mathlib4/: lake exe cache \
get && lake build Mathlib.Tactic.Ring\>\""}], "]"}]}], "Input",ExpressionUUID->\
"9456ad8e-c880-479a-95ce-2f8458b31b80"],

