   RowBox[{"ftaEnv", "[", "\"\<IsAlgClosed.splits_codomain\>\"", "]"}], 
   "[", "\"\<Parameters\>\"", "]"}], " ", "//", " ", "Dataset"}]], "Input",Exp\
ressionUUID->"57e7c273-552a-458a-a842-f63498e872e8"],

Cell["Consequences", "Section",ExpressionUUID->"88ce8def-7d4e-4739-9f0e-194a7d2f2b2a"],

Cell["N-th roots exist in algebraically closed fields:", "Text",ExpressionUUID->"0f4a083b-5490-4f88-9a86-8c1b2beb0c8e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ftaEnv", "[", "\"\<IsAlgClosed.exists_pow_nat_eq\>\"", "]"}], 
  "[", "\"\<TypeForm\>\"", "]"}]], "Input",ExpressionUUID->"a0fdc452-762d-\
42ae-99fc-1dfa8bfdd912"],

Cell["Square roots exist:", "Text",ExpressionUUID->"9c7b1a3b-c1a7-4953-969b-637bcceaf4b0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ftaEnv", "[", "\"\<IsAlgClosed.exists_eq_mul_self\>\"", "]"}], 
  "[", "\"\<TypeForm\>\"", "]"}]], "Input",ExpressionUUID->"58a1aede-afc8-\
4c2c-bdb2-8a863dbc359f"],

Cell["Algebraically closed fields are necessarily infinite:", "Text",ExpressionUUID->"9d736a22-a002-46ee-b55b-57cc4ddaa3c2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ftaEnv", "[", "\"\<IsAlgClosed.instInfinite\>\"", "]"}], 
  "[", "\"\<TypeForm\>\"", "]"}]], "Input",ExpressionUUID->"3331a9e9-92f7-\
47cd-8fa1-8dbbf12cc7db"],

Cell["The construction of the typeclass", "Section",ExpressionUUID->"f2b28b02-f69e-4399-bda4-084f2adb7690"],

Cell[TextData[{
 "The ",
 Cell["IsAlgClosed", "InlineCode",ExpressionUUID->
  "ad4ac0b0-4daf-4b82-9e8d-3899f5715ba0"],
 " typeclass is built from a single axiom: all polynomials split:"
}], "Text",ExpressionUUID->"02589e56-9554-43ce-948c-0654b5bcc8ba"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ftaEnv", "[", "\"\<IsAlgClosed.mk\>\"", "]"}], 
  "[", "\"\<TypeForm\>\"", "]"}]], "Input",ExpressionUUID->"c7aed43e-b035-\
404a-9da8-819bc75cc802"],

