essionUUID->"918f1b8c-a543-4288-be0c-b18da081bcd3"],

Cell[BoxData[
 RowBox[{"s0", "[", "\"\<Complete\>\"", "]"}]], "Input",ExpressionUUID->"9129ccd4-ef1c-49db-ba25-969709b5ffea"]
