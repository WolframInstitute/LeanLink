4c04-a758-345cbcb0919f"],

Cell["A simple proof: commutativity", "Section",ExpressionUUID->"d615dc2a-3e5b-472f-b25e-4e3db1f40e16"],

Cell["\<\
To see LeanLink's tactic engine in action, let's prove something simple from \
the algebra environment:\
\>", "Text",ExpressionUUID->"48cad0e0-5ba3-46df-ab9c-784f0dc67a27"],

Cell[BoxData[
 RowBox[{"s0", " ", "=", " ", 
  RowBox[{"LeanState", "[", 
   RowBox[{"algEnv", ",", " ", "\"\<mul_one\>\""}], "]"}]}]], "Input",Expressi\
onUUID->"647b0df5-6407-4284-bee3-e5dcc63efdde"],

