   RowBox[{"ftaEnv", "[", "\"\<IsAlgClosed.mk\>\"", "]"}], 
   "[", "\"\<Parameters\>\"", "]"}], " ", "//", " ", "Dataset"}]], "Input",Exp\
ressionUUID->"1005228f-456e-4ce7-8e2a-df5f32d4b0e2"],

Cell["Expression tree of the FTA", "Section",ExpressionUUID->"a2ec3cd8-4225-47ba-9fcc-d8fb8aaba5e6"],

Cell[TextData[{
 "Visualize the full type of ",
 Cell["exists_aeval_eq_zero", "InlineCode",ExpressionUUID->
  "040fc564-0eea-4036-9564-5a15eb197b2a"],
 " as a graph:"
}], "Text",ExpressionUUID->"af073c7c-068d-405f-b10f-dbc4a2fc3558"],

